<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>pl.octadecimal.workspace-api-m1-server</string>
  <key>UserName</key>
  <string>@CEO_USER@</string>
  <key>GroupName</key>
  <string>staff</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>@REPO_ROOT@/scripts/octa-workspace-api-m1.sh</string>
  </array>
  <key>WorkingDirectory</key>
  <string>@REPO_ROOT@</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ThrottleInterval</key>
  <integer>30</integer>
  <key>StandardOutPath</key>
  <string>@CEO_HOME@/.octa/logs/workspace-api-m1-launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>@CEO_HOME@/.octa/logs/workspace-api-m1-launchd.err.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>@CEO_HOME@</string>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>KNOWLEDGE_ROOT</key>
    <string>@CEO_HOME@/Developer/Knowledge</string>
    <key>WORKSPACE_ENABLED</key>
    <string>1</string>
    <key>OCTA_NODE</key>
    <string>m1</string>
    <key>LLM_PROVIDER</key>
    <string>dry</string>
    <key>RAG_BACKEND</key>
    <string>memory</string>
    <key>CALENDAR_PROVIDER</key>
    <string>cache</string>
    <key>OCTA_WORKSPACE_SKIP_SEED</key>
    <string>1</string>
    <key>OCTA_WORKSPACE_SKIP_UV_SYNC</key>
    <string>1</string>
  </dict>
</dict>
</plist>
